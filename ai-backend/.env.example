# ============================================================
# NL2SQL AI Backend — Environment Variables Template
# Copy to .env and fill in your values.
# ============================================================

# ─── LLM Provider ───────────────────────────────────────────
# Provider: ollama | openai
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b-instruct-q4_K_M
LLM_FAST_MODEL=llama3.2:3b

# Ollama (local): http://localhost:11434
# OpenAI:        https://api.openai.com/v1
LLM_BASE_URL=http://localhost:11434

# OpenAI API key — only required when LLM_PROVIDER=openai
OPENAI_API_KEY=

LLM_REQUEST_TIMEOUT=180
LLM_MAX_RETRIES=2

# ─── ChromaDB Embeddings ─────────────────────────────────────
# Mode: nomic (semantic, recommended) | local_hash (offline, fast)
CHROMA_EMBEDDING_MODE=nomic
CHROMA_EMBED_MODEL=nomic-embed-text

# ─── Agent ───────────────────────────────────────────────────
MAX_RETRY_COUNT=3
DEBUG=false

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated allowed origins, or * for all (development only)
ALLOWED_ORIGINS=*

# ─── Gunicorn (Docker / production) ─────────────────────────
WORKERS=2
LOG_LEVEL=info
